# Копируйте в .env и заполните значения. Не коммитьте .env в репозиторий.

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=ваш_пароль
POSTGRES_DB=vitrina_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Сессия и админка (обязательно сменить в production)
SESSION_SECRET_KEY=supersecretkey123
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Сайт и карты
SITE_URL=http://127.0.0.1:8000
YANDEX_MAPS_API_KEY=

# Пагинация и лимиты
PAGE_SIZE_PUBLIC=12
PAGE_SIZE_DASHBOARD=20
MAIN_PAGE_LIMIT=3
UPLOAD_MAX_FILE_SIZE=10485760

# Контакты для фида Авито (можно задать в дашборде → Настройки)
AVITO_MANAGER_NAME=
AVITO_CONTACT_PHONE=
MANAGER_NAME=
CONTACT_PHONE=

# Production: задайте ENVIRONMENT=production и PRODUCTION=true, смените SESSION_SECRET_KEY и ADMIN_PASSWORD
ENVIRONMENT=
PRODUCTION=

# Авито Autoload API (опционально; для выгрузки фида через API)
# AVITO_API_CLIENT_ID=
# AVITO_API_CLIENT_SECRET=
# AVITO_API_BASE_URL=https://api.avito.ru
# AVITO_AUTOLOAD_UPLOAD_URL=https://api.avito.ru/autoload/v1/upload
